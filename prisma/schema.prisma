generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x", "linux-musl", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserStatus {
  ACTIVE
  SUSPENDED
  DELETED
}

enum KycStatus {
  NOT_STARTED
  PENDING
  VERIFIED
  REJECTED
  EXPIRED
}

enum RoleCode {
  END_USER
  SUPER_ADMIN
  INTERNAL_ADMIN
  CONTENT_ADMIN
  SUPPORT_STAFF
  BANK_ADMIN
  BANK_MARKETER
  BANK_ANALYST
  BANK_VIEWER
}

enum OrganizationType {
  INTERNAL
  BANK
  PARTNER
}

enum FilePurpose {
  AVATAR
  EKYC
  OCR_UPLOAD
  CHAT_ATTACHMENT
  CAMPAIGN_ASSET
  OTHER
}

enum ChatRole {
  USER
  ASSISTANT
  SYSTEM
  TOOL
}

enum ChatChannel {
  MAIN_CHAT
  PET_CHAT
}

enum TrendStatus {
  DRAFT
  PENDING_REVIEW
  APPROVED
  REJECTED
  DEPLOYED
  ARCHIVED
}

enum CampaignStatus {
  DRAFT
  ACTIVE
  PAUSED
  COMPLETED
  ARCHIVED
}

model User {
  id           String     @id @default(uuid())
  email        String?    @unique
  phone        String?    @unique
  passwordHash String
  status       UserStatus @default(ACTIVE)
  kycStatus    KycStatus  @default(NOT_STARTED)

  profile       UserProfile?
  roles         UserRole[]
  refreshTokens RefreshToken[]

  chatSessions ChatSession[]
  files        File[]
  ocrJobs      OcrJob[]
  petProfile   PetProfile?
  streak       UserStreak?

  organizationMembers OrganizationMember[]

  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
  EkycSession      EkycSession[]
  EkycInternalNote EkycInternalNote[]
}

model UserProfile {
  id           String  @id @default(uuid())
  userId       String  @unique
  fullName     String?
  displayName  String?
  avatarFileId String?

  user User @relation(fields: [userId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model UserRole {
  id     String   @id @default(uuid())
  userId String
  role   RoleCode

  user User @relation(fields: [userId], references: [id])

  createdAt DateTime @default(now())

  @@unique([userId, role])
}

model RefreshToken {
  id        String    @id @default(uuid())
  userId    String
  tokenHash String
  expiresAt DateTime
  revokedAt DateTime?

  user User @relation(fields: [userId], references: [id])

  createdAt DateTime @default(now())
}

model Organization {
  id      String           @id @default(uuid())
  name    String
  type    OrganizationType
  taxCode String?
  status  String           @default("ACTIVE")

  members   OrganizationMember[]
  campaigns Campaign[]
  vouchers  Voucher[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model OrganizationMember {
  id             String  @id @default(uuid())
  organizationId String
  userId         String
  title          String?

  organization Organization @relation(fields: [organizationId], references: [id])
  user         User         @relation(fields: [userId], references: [id])

  createdAt DateTime @default(now())

  @@unique([organizationId, userId])
}

model EkycVerification {
  id           String    @id @default(uuid())
  userId       String
  provider     String    @default("VNPT")
  providerRef  String?
  status       KycStatus @default(PENDING)
  resultJson   Json?
  frontFileId  String?
  backFileId   String?
  selfieFileId String?
  verifiedAt   DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model File {
  id           String      @id @default(uuid())
  ownerId      String?
  bucket       String
  objectKey    String
  originalName String?
  mimeType     String?
  sizeBytes    Int?
  purpose      FilePurpose @default(OTHER)

  owner User? @relation(fields: [ownerId], references: [id])

  createdAt    DateTime       @default(now())
  EkycDocument EkycDocument[]
}

model OcrJob {
  id           String  @id @default(uuid())
  userId       String
  fileId       String
  provider     String  @default("VNPT")
  status       String  @default("PENDING")
  resultJson   Json?
  errorMessage String?

  user User @relation(fields: [userId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ChatSession {
  id       String      @id @default(uuid())
  userId   String
  channel  ChatChannel @default(MAIN_CHAT)
  title    String?
  metadata Json?

  user     User          @relation(fields: [userId], references: [id])
  messages ChatMessage[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ChatMessage {
  id        String   @id @default(uuid())
  sessionId String
  role      ChatRole
  content   String
  metadata  Json?

  session ChatSession @relation(fields: [sessionId], references: [id])

  createdAt DateTime @default(now())
}

model PetProfile {
  id       String @id @default(uuid())
  userId   String @unique
  name     String @default("Pockie")
  level    Int    @default(1)
  mood     String @default("NORMAL")
  metadata Json?

  user User @relation(fields: [userId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model PetInteraction {
  id        String @id @default(uuid())
  userId    String
  eventName String
  payload   Json?

  createdAt DateTime @default(now())
}

model UserStreak {
  id             String    @id @default(uuid())
  userId         String    @unique
  currentDays    Int       @default(0)
  longestDays    Int       @default(0)
  lastActiveDate DateTime?

  user User @relation(fields: [userId], references: [id])

  updatedAt DateTime @updatedAt
}

model Voucher {
  id                String    @id @default(uuid())
  organizationId    String?
  title             String
  description       String?
  code              String?
  totalQuantity     Int?
  remainingQuantity Int?
  startsAt          DateTime?
  endsAt            DateTime?
  metadata          Json?

  organization Organization?  @relation(fields: [organizationId], references: [id])
  claims       VoucherClaim[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model VoucherClaim {
  id         String    @id @default(uuid())
  voucherId  String
  userId     String
  status     String    @default("CLAIMED")
  claimedAt  DateTime  @default(now())
  redeemedAt DateTime?

  voucher Voucher @relation(fields: [voucherId], references: [id])

  @@unique([voucherId, userId])
}

model Trend {
  id         String      @id @default(uuid())
  source     String      @default("VNSOCIAL")
  externalId String?
  title      String
  summary    String?
  category   String?
  score      Float?
  status     TrendStatus @default(PENDING_REVIEW)
  rawJson    Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Campaign {
  id             String         @id @default(uuid())
  organizationId String
  name           String
  objective      String?
  status         CampaignStatus @default(DRAFT)
  configJson     Json?
  startsAt       DateTime?
  endsAt         DateTime?

  organization Organization     @relation(fields: [organizationId], references: [id])
  reports      CampaignReport[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model CampaignReport {
  id          String  @id @default(uuid())
  campaignId  String
  title       String
  content     String
  metricsJson Json?
  aiSummary   String?

  campaign Campaign @relation(fields: [campaignId], references: [id])

  createdAt DateTime @default(now())
}

model AnalyticsEvent {
  id        String  @id @default(uuid())
  userId    String?
  sessionId String?
  eventName String
  page      String?
  feature   String?
  payload   Json?

  createdAt DateTime @default(now())

  @@index([eventName])
  @@index([feature])
  @@index([createdAt])
}

model AdminActionLog {
  id          String  @id @default(uuid())
  actorUserId String
  action      String
  targetType  String?
  targetId    String?
  payload     Json?

  createdAt DateTime @default(now())
}

model Permission {
  id          String  @id @default(uuid())
  code        String  @unique
  description String?

  rolePermissions RolePermission[]

  createdAt DateTime @default(now())
}

model RolePermission {
  id           String   @id @default(uuid())
  role         RoleCode
  permissionId String

  permission Permission @relation(fields: [permissionId], references: [id])

  createdAt DateTime @default(now())

  @@unique([role, permissionId])
}

enum LoginAttemptResult {
  SUCCESS
  FAILED_PASSWORD
  USER_NOT_FOUND
  USER_SUSPENDED
  RATE_LIMITED
  INTERNAL_ACCESS_DENIED
}

model LoginAttempt {
  id        String             @id @default(uuid())
  email     String
  ipAddress String?
  userAgent String?
  result    LoginAttemptResult

  createdAt DateTime @default(now())
}

// ==========================================
// EKYC REVIEW SYSTEM
// ==========================================

enum EkycSessionStatus {
  DRAFT
  UPLOADING
  PROCESSING
  REVIEW_REQUIRED
  VERIFIED
  REJECTED
  RETRY_REQUIRED
  EXPIRED
  FAILED
}

enum EkycFinalDecision {
  PASS
  REVIEW
  FAIL
  RETRY
  UNKNOWN
}

enum EkycDocumentSide {
  FRONT
  BACK
  SELFIE
  FACE_NEAR
  FACE_FAR
  SCAN_3D
  UNKNOWN
}

enum EkycDocumentType {
  CCCD
  CMND_9
  CMND_12
  CCCD_CHIP
  PASSPORT
  DRIVER_LICENSE
  MILITARY_ID
  FACE
  UNKNOWN
}

enum EkycProviderApiName {
  UPLOAD_FILE
  OCR_ID
  LIVENESS_CARD
  FACE_LIVENESS_2D
  FACE_LIVENESS_3D
  FACE_COMPARE
  FACE_COMPARE_GENERAL
  MASK_FACE
}

enum EkycRiskLevel {
  LOW
  MEDIUM
  HIGH
  CRITICAL
  UNKNOWN
}

model EkycSession {
  id             String            @id @default(uuid())
  userId         String
  status         EkycSessionStatus @default(DRAFT)
  finalDecision  EkycFinalDecision @default(UNKNOWN)
  riskLevel      EkycRiskLevel     @default(UNKNOWN)
  decisionReason String?
  clientSession  String?

  user             User                  @relation(fields: [userId], references: [id])
  documents        EkycDocument[]
  decisionLogs     EkycDecisionLog[]
  internalNotes    EkycInternalNote[]
  providerRequests EkycProviderRequest[]

  ocrResult    EkycOcrResult?
  livenessCard EkycLivenessCardResult?
  faceLiveness EkycFaceLivenessResult?
  faceCompare  EkycFaceCompareResult?
  maskResult   EkycMaskResult?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model EkycDocument {
  id           String           @id @default(uuid())
  sessionId    String
  side         EkycDocumentSide
  documentType EkycDocumentType @default(UNKNOWN)
  fileId       String?

  session EkycSession @relation(fields: [sessionId], references: [id])
  file    File?       @relation(fields: [fileId], references: [id])

  vnptUpload VnptFileUpload?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model VnptFileUpload {
  id            String   @id @default(uuid())
  documentId    String   @unique
  vnptHash      String
  hashExpiresAt DateTime
  rawResponse   Json?

  document EkycDocument @relation(fields: [documentId], references: [id])

  createdAt DateTime @default(now())
}

model EkycOcrResult {
  id          String  @id @default(uuid())
  sessionId   String  @unique
  statusCode  Int
  message     String?
  rawResponse Json?

  session   EkycSession            @relation(fields: [sessionId], references: [id])
  fields    EkycOcrField[]
  warnings  EkycWarning[]
  tampering EkycTamperingFinding[]

  createdAt DateTime @default(now())
}

model EkycOcrField {
  id          String @id @default(uuid())
  ocrResultId String
  fieldName   String
  fieldValue  String
  probability Float?

  ocrResult EkycOcrResult @relation(fields: [ocrResultId], references: [id])
}

model EkycWarning {
  id          String  @id @default(uuid())
  ocrResultId String
  code        String
  message     String?
  severity    String  @default("MEDIUM")
  shouldBlock Boolean @default(false)

  ocrResult EkycOcrResult @relation(fields: [ocrResultId], references: [id])
}

model EkycTamperingFinding {
  id          String  @id @default(uuid())
  ocrResultId String
  code        String
  message     String?
  severity    String  @default("HIGH")

  ocrResult EkycOcrResult @relation(fields: [ocrResultId], references: [id])
}

model EkycLivenessCardResult {
  id             String  @id @default(uuid())
  sessionId      String  @unique
  liveness       String
  livenessMsg    String?
  faceSwapping   Boolean @default(false)
  fakeLiveness   Boolean @default(false)
  fakePrintPhoto Boolean @default(false)
  rawResponse    Json?

  session EkycSession @relation(fields: [sessionId], references: [id])

  createdAt DateTime @default(now())
}

model EkycFaceLivenessResult {
  id            String  @id @default(uuid())
  sessionId     String  @unique
  mode          String  @default("FACE_2D")
  liveness      String
  livenessMsg   String?
  livenessProb  Float?
  blurFace      String?
  isEyeOpen     String?
  multipleFaces Boolean @default(false)
  rawResponse   Json?

  session EkycSession @relation(fields: [sessionId], references: [id])

  createdAt DateTime @default(now())
}

model EkycFaceCompareResult {
  id            String  @id @default(uuid())
  sessionId     String  @unique
  msg           String
  prob          Float?
  multipleFaces Boolean @default(false)
  matchWarning  String?
  rawResponse   Json?

  session EkycSession @relation(fields: [sessionId], references: [id])

  createdAt DateTime @default(now())
}

model EkycMaskResult {
  id          String @id @default(uuid())
  sessionId   String @unique
  masked      String
  rawResponse Json?

  session EkycSession @relation(fields: [sessionId], references: [id])

  createdAt DateTime @default(now())
}

model EkycProviderRequest {
  id              String              @id @default(uuid())
  sessionId       String?
  provider        String              @default("VNPT")
  apiName         EkycProviderApiName
  endpoint        String
  httpMethod      String              @default("POST")
  requestPayload  Json?
  responsePayload Json?
  statusCode      Int?
  message         String?
  errorMessage    String?
  durationMs      Int?

  session EkycSession? @relation(fields: [sessionId], references: [id])

  createdAt DateTime @default(now())
}

model EkycDecisionLog {
  id        String            @id @default(uuid())
  sessionId String
  decision  EkycFinalDecision
  reason    String?

  session EkycSession @relation(fields: [sessionId], references: [id])

  createdAt DateTime @default(now())
}

model EkycInternalNote {
  id        String @id @default(uuid())
  sessionId String
  authorId  String
  note      String

  session EkycSession @relation(fields: [sessionId], references: [id])
  author  User        @relation(fields: [authorId], references: [id])

  createdAt DateTime @default(now())
}
