generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x", "linux-musl", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserStatus {
  ACTIVE
  SUSPENDED
  DELETED
}

enum KycStatus {
  NOT_STARTED
  PENDING
  VERIFIED
  REJECTED
  EXPIRED
}

enum RoleCode {
  END_USER
  SUPER_ADMIN
  INTERNAL_ADMIN
  CONTENT_ADMIN
  SUPPORT_STAFF
  BANK_ADMIN
  BANK_MARKETER
  BANK_ANALYST
  BANK_VIEWER
}

enum OrganizationType {
  INTERNAL
  BANK
  PARTNER
}

enum FilePurpose {
  AVATAR
  EKYC
  OCR_UPLOAD
  CHAT_ATTACHMENT
  CAMPAIGN_ASSET
  OTHER
}

enum ChatRole {
  USER
  ASSISTANT
  SYSTEM
  TOOL
}

enum ChatChannel {
  MAIN_CHAT
  PET_CHAT
}

enum TrendStatus {
  DRAFT
  PENDING_REVIEW
  APPROVED
  REJECTED
  DEPLOYED
  ARCHIVED
}

enum CampaignStatus {
  DRAFT
  ACTIVE
  PAUSED
  COMPLETED
  ARCHIVED
}

enum ApprovalStatus {
  DRAFT
  PENDING
  APPROVED
  REJECTED
}

enum VnSocialProjectType {
  TOPIC_POLICY
  PERSONAL_POST
  UNKNOWN
}

enum VnSocialSyncJobType {
  PROJECTS
  POSTS
  HOT_KEYWORDS
  HOT_POSTS
}

enum VnSocialSyncJobStatus {
  PENDING
  RUNNING
  SUCCESS
  FAILED
}

enum VoucherClaimScope {
  PER_ACCOUNT
  PER_VERIFIED_IDENTITY
  PER_CAMPAIGN_IDENTITY
}

enum VerifiedIdentityStatus {
  VERIFIED
  REVIEW_REQUIRED
  REJECTED
  DISABLED
}

enum VoucherClaimAttemptResult {
  SUCCESS
  REJECTED_NOT_VERIFIED
  REJECTED_NO_VERIFIED_IDENTITY
  REJECTED_DUPLICATE_ACCOUNT
  REJECTED_DUPLICATE_IDENTITY
  REJECTED_DUPLICATE_CAMPAIGN
  REJECTED_OUT_OF_STOCK
  REJECTED_INACTIVE
  REJECTED_RULES
}

model User {
  id           String     @id @default(uuid())
  email        String?    @unique
  phone        String?    @unique
  passwordHash String
  status       UserStatus @default(ACTIVE)
  kycStatus    KycStatus  @default(NOT_STARTED)
  verifiedIdentityId String?

  profile       UserProfile?
  roles         UserRole[]
  refreshTokens RefreshToken[]
  passwordResetTokens PasswordResetToken[]

  chatSessions ChatSession[]
  files        File[]
  ocrJobs      OcrJob[]
  petProfile   PetProfile?
  streak       UserStreak?

  organizationMembers OrganizationMember[]

  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
  EkycSession      EkycSession[]
  EkycInternalNote EkycInternalNote[]

  // --- Task 3 Relations ---
  authIdentities            AuthIdentity[]
  gamificationProfile       UserGamificationProfile?
  xpEvents                  XpEvent[]
  userMissionLogs           UserMissionLog[]
  userStreakDays            UserStreakDay[]
  wallets                   Wallet[]
  financialTransactions     FinancialTransaction[]
  monthlyBudgets            MonthlyBudget[]
  monthlyFinancialSummaries MonthlyFinancialSummary[]
  notifications             Notification[]
  financialInsights         FinancialInsight[]
  aiInsightJobs             AiInsightJob[]
  verifiedIdentity          VerifiedIdentity? @relation(fields: [verifiedIdentityId], references: [id])
  voucherClaims             VoucherClaim[]
  voucherClaimAttempts      VoucherClaimAttempt[]
  voucherCampaignLocks      VoucherCampaignIdentityLock[]
}

model UserProfile {
  id           String  @id @default(uuid())
  userId       String  @unique
  fullName     String?
  displayName  String?
  avatarFileId String?

  user User @relation(fields: [userId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model UserRole {
  id     String   @id @default(uuid())
  userId String
  role   RoleCode

  user User @relation(fields: [userId], references: [id])

  createdAt DateTime @default(now())

  @@unique([userId, role])
}

model RefreshToken {
  id        String    @id @default(uuid())
  userId    String
  tokenHash String
  expiresAt DateTime
  revokedAt DateTime?

  user User @relation(fields: [userId], references: [id])

  createdAt DateTime @default(now())
}

model PasswordResetToken {
  id        String    @id @default(uuid())
  userId    String
  tokenHash String
  expiresAt DateTime
  usedAt    DateTime?

  user User @relation(fields: [userId], references: [id])

  createdAt DateTime @default(now())
}

model Organization {
  id      String           @id @default(uuid())
  name    String
  type    OrganizationType
  taxCode String?
  status  String           @default("ACTIVE")

  members   OrganizationMember[]
  campaigns Campaign[]
  vouchers  Voucher[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model OrganizationMember {
  id             String  @id @default(uuid())
  organizationId String
  userId         String
  title          String?

  organization Organization @relation(fields: [organizationId], references: [id])
  user         User         @relation(fields: [userId], references: [id])

  createdAt DateTime @default(now())

  @@unique([organizationId, userId])
}

model EkycVerification {
  id           String    @id @default(uuid())
  userId       String
  provider     String    @default("VNPT")
  providerRef  String?
  status       KycStatus @default(PENDING)
  resultJson   Json?
  frontFileId  String?
  backFileId   String?
  selfieFileId String?
  verifiedAt   DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model File {
  id           String      @id @default(uuid())
  ownerId      String?
  bucket       String
  objectKey    String
  originalName String?
  mimeType     String?
  sizeBytes    Int?
  purpose      FilePurpose @default(OTHER)

  owner User? @relation(fields: [ownerId], references: [id])

  createdAt    DateTime       @default(now())
  EkycDocument EkycDocument[]
}

model OcrJob {
  id           String  @id @default(uuid())
  userId       String
  fileId       String
  provider     String  @default("VNPT")
  status       String  @default("PENDING")
  resultJson   Json?
  errorMessage String?

  user User @relation(fields: [userId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ChatSession {
  id       String      @id @default(uuid())
  userId   String
  channel  ChatChannel @default(MAIN_CHAT)
  title    String?
  metadata Json?

  user     User          @relation(fields: [userId], references: [id])
  messages ChatMessage[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ChatMessage {
  id        String   @id @default(uuid())
  sessionId String
  role      ChatRole
  content   String
  metadata  Json?

  session ChatSession @relation(fields: [sessionId], references: [id])

  createdAt DateTime @default(now())
}

model PetProfile {
  id       String @id @default(uuid())
  userId   String @unique
  name     String @default("Pockie")
  level    Int    @default(1)
  mood     String @default("NORMAL")
  metadata Json?

  user User @relation(fields: [userId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model PetInteraction {
  id        String @id @default(uuid())
  userId    String
  eventName String
  payload   Json?

  createdAt DateTime @default(now())
}

model UserStreak {
  id             String    @id @default(uuid())
  userId         String    @unique
  currentDays    Int       @default(0)
  longestDays    Int       @default(0)
  lastActiveDate DateTime?

  user User @relation(fields: [userId], references: [id])

  updatedAt DateTime @updatedAt
}

model Voucher {
  id                String    @id @default(uuid())
  organizationId    String?
  title             String
  description       String?
  code              String?
  totalQuantity     Int?
  remainingQuantity Int?
  startsAt          DateTime?
  endsAt            DateTime?
  metadata          Json?
  requiresKyc       Boolean   @default(true)
  claimScope        VoucherClaimScope @default(PER_VERIFIED_IDENTITY)
  campaignKey       String?
  approvalStatus    ApprovalStatus @default(DRAFT)
  approvedBy        String?

  organization Organization?  @relation(fields: [organizationId], references: [id])
  claims       VoucherClaim[]
  claimAttempts VoucherClaimAttempt[]
  campaignIdentityLocks VoucherCampaignIdentityLock[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model VoucherClaim {
  id         String    @id @default(uuid())
  voucherId  String
  userId     String
  verifiedIdentityId String?
  status     String    @default("CLAIMED")
  claimedAt  DateTime  @default(now())
  redeemedAt DateTime?
  campaignKey String?
  ipAddress  String?
  userAgent  String?
  metadata   Json?

  voucher Voucher @relation(fields: [voucherId], references: [id])
  user    User    @relation(fields: [userId], references: [id])
  verifiedIdentity VerifiedIdentity? @relation(fields: [verifiedIdentityId], references: [id])

  @@unique([voucherId, userId])
  @@unique([voucherId, verifiedIdentityId])
  @@index([campaignKey, verifiedIdentityId])
  @@index([userId, claimedAt])
}

model VoucherClaimAttempt {
  id                 String                    @id @default(uuid())
  voucherId          String
  userId             String
  verifiedIdentityId String?
  result             VoucherClaimAttemptResult
  reason             String?
  ipAddress          String?
  userAgent          String?
  metadata           Json?

  voucher           Voucher           @relation(fields: [voucherId], references: [id])
  user              User              @relation(fields: [userId], references: [id])
  verifiedIdentity  VerifiedIdentity? @relation(fields: [verifiedIdentityId], references: [id])

  createdAt DateTime @default(now())

  @@index([voucherId, createdAt])
  @@index([userId, createdAt])
  @@index([verifiedIdentityId, createdAt])
}

model VerifiedIdentity {
  id                   String                 @id @default(uuid())
  documentType         EkycDocumentType
  documentNumberHash   String
  documentNumberMasked String
  fullNameNormalized   String?
  dateOfBirth          String?
  provider             String                 @default("VNPT")
  sourceSessionId      String?
  riskLevel            EkycRiskLevel          @default(UNKNOWN)
  status               VerifiedIdentityStatus @default(VERIFIED)
  metadata             Json?

  users                User[]
  voucherClaims        VoucherClaim[]
  voucherClaimAttempts VoucherClaimAttempt[]
  campaignLocks        VoucherCampaignIdentityLock[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([documentType, documentNumberHash])
  @@index([status])
}

model VoucherCampaignIdentityLock {
  id                 String   @id @default(uuid())
  campaignKey        String
  verifiedIdentityId String
  voucherId          String
  userId             String
  createdAt          DateTime @default(now())

  verifiedIdentity VerifiedIdentity @relation(fields: [verifiedIdentityId], references: [id])
  voucher          Voucher          @relation(fields: [voucherId], references: [id])
  user             User             @relation(fields: [userId], references: [id])

  @@unique([campaignKey, verifiedIdentityId])
  @@index([voucherId, createdAt])
  @@index([userId, createdAt])
}

model Trend {
  id         String      @id @default(uuid())
  source     String      @default("VNSOCIAL")
  externalId String?
  title      String
  summary    String?
  category   String?
  sentiment  String?
  score      Float?
  status     TrendStatus @default(PENDING_REVIEW)
  origin     String?
  originRefId String?
  sourceChannel String?
  reviewNote String?
  deployedAt DateTime?
  projectId  String?
  rawJson    Json?

  project VnSocialProject? @relation(fields: [projectId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status, createdAt])
  @@index([projectId, status])
  @@index([externalId])
}

model VnSocialProject {
  id                String              @id @default(uuid())
  externalProjectId String?             @unique
  externalSourceId  String?
  name              String
  type              VnSocialProjectType @default(UNKNOWN)
  status            String              @default("ACTIVE")
  sourceName        String?
  rawJson           Json?

  posts        VnSocialPost[]
  hotKeywords  VnSocialHotKeyword[]
  hotPosts     VnSocialHotPost[]
  syncJobs     VnSocialSyncJob[]
  apiLogs      VnSocialApiLog[]
  trends       Trend[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([type, status])
}

model VnSocialPost {
  id              String   @id @default(uuid())
  externalDocId   String   @unique
  projectId       String
  source          String?
  sourceName      String?
  userName        String?
  postLink        String?
  domain          String?
  title           String?
  description     String?
  content         String?
  tags            Json?
  senti           String?
  isSpam          Boolean?
  postType        String?
  numInteractions Int?
  numComments     Int?
  numShares       Int?
  createDate      DateTime?
  updateDate      DateTime?
  rawJson         Json?

  project VnSocialProject @relation(fields: [projectId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([projectId, createDate])
  @@index([senti])
}

model VnSocialHotKeyword {
  id           String   @id @default(uuid())
  projectId    String
  keyword      String
  docCount     Int?
  sourceFilter String?
  startTime    DateTime?
  endTime      DateTime?
  score        Float?
  rawJson      Json?

  project VnSocialProject @relation(fields: [projectId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([projectId, keyword])
  @@index([projectId, createdAt])
}

model VnSocialHotPost {
  id              String   @id @default(uuid())
  externalDocId   String   @unique
  projectId       String
  source          String?
  sourceName      String?
  domain          String?
  postLink        String?
  title           String?
  description     String?
  content         String?
  senti           String?
  numInteractions Int?
  numComments     Int?
  numShares       Int?
  createDate      DateTime?
  updateDate      DateTime?
  rawJson         Json?

  project VnSocialProject @relation(fields: [projectId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([projectId, createDate])
  @@index([senti])
}

model VnSocialSyncJob {
  id           String              @id @default(uuid())
  projectId    String?
  jobType      VnSocialSyncJobType
  status       VnSocialSyncJobStatus @default(PENDING)
  pulledCount  Int                 @default(0)
  errorMessage String?
  payload      Json?
  startedAt    DateTime?
  finishedAt   DateTime?

  project VnSocialProject? @relation(fields: [projectId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([jobType, createdAt])
  @@index([status, createdAt])
}

model VnSocialApiLog {
  id              String   @id @default(uuid())
  projectId       String?
  endpoint        String
  httpMethod      String   @default("GET")
  requestPayload  Json?
  responsePayload Json?
  statusCode      Int?
  message         String?
  errorMessage    String?
  durationMs      Int?

  project VnSocialProject? @relation(fields: [projectId], references: [id])

  createdAt DateTime @default(now())

  @@index([projectId, createdAt])
  @@index([endpoint, createdAt])
}

model Campaign {
  id             String         @id @default(uuid())
  organizationId String
  name           String
  objective      String?
  status         CampaignStatus @default(DRAFT)
  approvalStatus ApprovalStatus @default(DRAFT)
  approvedBy     String?
  configJson     Json?
  startsAt       DateTime?
  endsAt         DateTime?

  organization Organization     @relation(fields: [organizationId], references: [id])
  reports      CampaignReport[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model CampaignReport {
  id          String  @id @default(uuid())
  campaignId  String
  title       String
  content     String
  metricsJson Json?
  aiSummary   String?

  campaign Campaign @relation(fields: [campaignId], references: [id])

  createdAt DateTime @default(now())
}

model AnalyticsEvent {
  id        String  @id @default(uuid())
  userId    String?
  sessionId String?
  eventName String
  page      String?
  feature   String?
  payload   Json?

  createdAt DateTime @default(now())

  @@index([eventName])
  @@index([feature])
  @@index([createdAt])
}

model AdminActionLog {
  id          String  @id @default(uuid())
  actorUserId String
  action      String
  targetType  String?
  targetId    String?
  payload     Json?

  createdAt DateTime @default(now())
}

model Permission {
  id          String  @id @default(uuid())
  code        String  @unique
  description String?

  rolePermissions RolePermission[]

  createdAt DateTime @default(now())
}

model RolePermission {
  id           String   @id @default(uuid())
  role         RoleCode
  permissionId String

  permission Permission @relation(fields: [permissionId], references: [id])

  createdAt DateTime @default(now())

  @@unique([role, permissionId])
}

enum LoginAttemptResult {
  SUCCESS
  FAILED_PASSWORD
  USER_NOT_FOUND
  USER_SUSPENDED
  RATE_LIMITED
  INTERNAL_ACCESS_DENIED
}

model LoginAttempt {
  id        String             @id @default(uuid())
  email     String
  ipAddress String?
  userAgent String?
  result    LoginAttemptResult

  createdAt DateTime @default(now())
}

// ==========================================
// EKYC REVIEW SYSTEM
// ==========================================

enum EkycSessionStatus {
  DRAFT
  UPLOADING
  PROCESSING
  REVIEW_REQUIRED
  VERIFIED
  REJECTED
  RETRY_REQUIRED
  EXPIRED
  FAILED
}

enum EkycFinalDecision {
  PASS
  REVIEW
  FAIL
  RETRY
  UNKNOWN
}

enum EkycDocumentSide {
  FRONT
  BACK
  SELFIE
  FACE_NEAR
  FACE_FAR
  SCAN_3D
  UNKNOWN
}

enum EkycDocumentType {
  CCCD
  CMND_9
  CMND_12
  CCCD_CHIP
  PASSPORT
  DRIVER_LICENSE
  MILITARY_ID
  FACE
  UNKNOWN
}

enum EkycProviderApiName {
  UPLOAD_FILE
  OCR_ID
  LIVENESS_CARD
  FACE_LIVENESS_2D
  FACE_LIVENESS_3D
  FACE_COMPARE
  FACE_COMPARE_GENERAL
  MASK_FACE
}

enum EkycRiskLevel {
  LOW
  MEDIUM
  HIGH
  CRITICAL
  UNKNOWN
}

model EkycSession {
  id             String            @id @default(uuid())
  userId         String
  status         EkycSessionStatus @default(DRAFT)
  finalDecision  EkycFinalDecision @default(UNKNOWN)
  riskLevel      EkycRiskLevel     @default(UNKNOWN)
  decisionReason String?
  clientSession  String?

  user             User                  @relation(fields: [userId], references: [id])
  documents        EkycDocument[]
  decisionLogs     EkycDecisionLog[]
  internalNotes    EkycInternalNote[]
  providerRequests EkycProviderRequest[]

  ocrResult    EkycOcrResult?
  livenessCard EkycLivenessCardResult?
  faceLiveness EkycFaceLivenessResult?
  faceCompare  EkycFaceCompareResult?
  maskResult   EkycMaskResult?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model EkycDocument {
  id           String           @id @default(uuid())
  sessionId    String
  side         EkycDocumentSide
  documentType EkycDocumentType @default(UNKNOWN)
  fileId       String?

  session EkycSession @relation(fields: [sessionId], references: [id])
  file    File?       @relation(fields: [fileId], references: [id])

  vnptUpload VnptFileUpload?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model VnptFileUpload {
  id            String   @id @default(uuid())
  documentId    String   @unique
  vnptHash      String
  hashExpiresAt DateTime
  rawResponse   Json?

  document EkycDocument @relation(fields: [documentId], references: [id])

  createdAt DateTime @default(now())
}

model EkycOcrResult {
  id          String  @id @default(uuid())
  sessionId   String  @unique
  statusCode  Int
  message     String?
  rawResponse Json?

  session   EkycSession            @relation(fields: [sessionId], references: [id])
  fields    EkycOcrField[]
  warnings  EkycWarning[]
  tampering EkycTamperingFinding[]

  createdAt DateTime @default(now())
}

model EkycOcrField {
  id          String @id @default(uuid())
  ocrResultId String
  fieldName   String
  fieldValue  String
  probability Float?

  ocrResult EkycOcrResult @relation(fields: [ocrResultId], references: [id])
}

model EkycWarning {
  id          String  @id @default(uuid())
  ocrResultId String
  code        String
  message     String?
  severity    String  @default("MEDIUM")
  shouldBlock Boolean @default(false)

  ocrResult EkycOcrResult @relation(fields: [ocrResultId], references: [id])
}

model EkycTamperingFinding {
  id          String  @id @default(uuid())
  ocrResultId String
  code        String
  message     String?
  severity    String  @default("HIGH")

  ocrResult EkycOcrResult @relation(fields: [ocrResultId], references: [id])
}

model EkycLivenessCardResult {
  id             String  @id @default(uuid())
  sessionId      String  @unique
  liveness       String
  livenessMsg    String?
  faceSwapping   Boolean @default(false)
  fakeLiveness   Boolean @default(false)
  fakePrintPhoto Boolean @default(false)
  rawResponse    Json?

  session EkycSession @relation(fields: [sessionId], references: [id])

  createdAt DateTime @default(now())
}

model EkycFaceLivenessResult {
  id            String  @id @default(uuid())
  sessionId     String  @unique
  mode          String  @default("FACE_2D")
  liveness      String
  livenessMsg   String?
  livenessProb  Float?
  blurFace      String?
  isEyeOpen     String?
  multipleFaces Boolean @default(false)
  rawResponse   Json?

  session EkycSession @relation(fields: [sessionId], references: [id])

  createdAt DateTime @default(now())
}

model EkycFaceCompareResult {
  id            String  @id @default(uuid())
  sessionId     String  @unique
  msg           String
  prob          Float?
  multipleFaces Boolean @default(false)
  matchWarning  String?
  rawResponse   Json?

  session EkycSession @relation(fields: [sessionId], references: [id])

  createdAt DateTime @default(now())
}

model EkycMaskResult {
  id          String @id @default(uuid())
  sessionId   String @unique
  masked      String
  rawResponse Json?

  session EkycSession @relation(fields: [sessionId], references: [id])

  createdAt DateTime @default(now())
}

model EkycProviderRequest {
  id              String              @id @default(uuid())
  sessionId       String?
  provider        String              @default("VNPT")
  apiName         EkycProviderApiName
  endpoint        String
  httpMethod      String              @default("POST")
  requestPayload  Json?
  responsePayload Json?
  statusCode      Int?
  message         String?
  errorMessage    String?
  durationMs      Int?

  session EkycSession? @relation(fields: [sessionId], references: [id])

  createdAt DateTime @default(now())
}

model EkycDecisionLog {
  id        String            @id @default(uuid())
  sessionId String
  decision  EkycFinalDecision
  reason    String?

  session EkycSession @relation(fields: [sessionId], references: [id])

  createdAt DateTime @default(now())
}

model EkycInternalNote {
  id        String @id @default(uuid())
  sessionId String
  authorId  String
  note      String

  session EkycSession @relation(fields: [sessionId], references: [id])
  author  User        @relation(fields: [authorId], references: [id])

  createdAt DateTime @default(now())
}

// ==========================================
// USER DASHBOARD / GAMIFICATION / FINANCE
// ==========================================

model AuthIdentity {
  id             String  @id @default(uuid())
  userId         String
  provider       String
  providerUserId String
  email          String?

  user User @relation(fields: [userId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([provider, providerUserId])
}

model UserGamificationProfile {
  id                String    @id @default(uuid())
  userId            String    @unique
  level             Int       @default(1)
  currentXp         Int       @default(0)
  totalXp           Int       @default(0)
  currentStreakDays Int       @default(0)
  longestStreakDays Int       @default(0)
  lastActiveDate    DateTime?

  user User @relation(fields: [userId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model XpEvent {
  id         String  @id @default(uuid())
  userId     String
  sourceType String
  sourceId   String?
  xpAmount   Int
  reason     String?

  user User @relation(fields: [userId], references: [id])

  createdAt DateTime @default(now())
}

model LevelRule {
  id              String  @id @default(uuid())
  level           Int     @unique
  requiredTotalXp Int
  title           String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Mission {
  id          String  @id @default(uuid())
  code        String  @unique
  title       String
  description String?
  missionType String
  targetValue Int     @default(1)
  xpReward    Int     @default(0)
  status      String  @default("ACTIVE")
  metadata    Json?

  userMissionLogs UserMissionLog[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model UserMissionLog {
  id          String    @id @default(uuid())
  userId      String
  missionId   String
  date        DateTime  @db.Date
  status      String    @default("PENDING")
  progress    Int       @default(0)
  completedAt DateTime?
  xpAwarded   Int       @default(0)
  metadata    Json?

  user    User    @relation(fields: [userId], references: [id])
  mission Mission @relation(fields: [missionId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, missionId, date])
}

model UserStreakDay {
  id                    String   @id @default(uuid())
  userId                String
  date                  DateTime @db.Date
  isCompleted           Boolean  @default(false)
  completedMissionCount Int      @default(0)
  xpAwarded             Int      @default(0)

  user User @relation(fields: [userId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, date])
}

model Wallet {
  id         String  @id @default(uuid())
  userId     String
  name       String
  walletType String  @default("CASH")
  currency   String  @default("VND")
  balance    Decimal @default(0) @db.Decimal(18, 2)
  status     String  @default("ACTIVE")

  user         User                   @relation(fields: [userId], references: [id])
  transactions FinancialTransaction[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, name])
  @@map("wallets")
}

model FinancialCategory {
  id       String  @id @default(uuid())
  code     String? @unique
  name     String
  type     String
  icon     String?
  color    String?
  parentId String?
  isSystem Boolean @default(false)

  transactions FinancialTransaction[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("financial_categories")
}

model FinancialTransaction {
  id              String   @id @default(uuid())
  userId          String
  walletId        String
  categoryId      String
  amount          Decimal  @db.Decimal(18, 2)
  currency        String   @default("VND")
  transactionType String
  title           String
  merchantName    String?
  description     String?
  transactionDate DateTime
  source          String   @default("MANUAL")
  sourceRefId     String?

  user     User              @relation(fields: [userId], references: [id])
  wallet   Wallet            @relation(fields: [walletId], references: [id])
  category FinancialCategory @relation(fields: [categoryId], references: [id])

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@map("financial_transactions")
}

model MonthlyBudget {
  id          String  @id @default(uuid())
  userId      String
  month       String // YYYY-MM
  totalBudget Decimal @db.Decimal(18, 2)
  currency    String  @default("VND")

  user User @relation(fields: [userId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, month])
  @@map("monthly_budgets")
}

model MonthlyFinancialSummary {
  id              String  @id @default(uuid())
  userId          String
  month           String // YYYY-MM
  totalIncome     Decimal @default(0) @db.Decimal(18, 2)
  totalExpense    Decimal @default(0) @db.Decimal(18, 2)
  totalBudget     Decimal @default(0) @db.Decimal(18, 2)
  remainingAmount Decimal @default(0) @db.Decimal(18, 2)
  topCategoryId   String?
  summaryJson     Json?

  user User @relation(fields: [userId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, month])
  @@map("monthly_financial_summaries")
}

model Notification {
  id       String    @id @default(uuid())
  userId   String
  type     String
  title    String
  body     String
  dataJson Json?
  readAt   DateTime?

  user User @relation(fields: [userId], references: [id])

  createdAt DateTime @default(now())
}

model FinancialInsight {
  id            String @id @default(uuid())
  userId        String
  month         String // YYYY-MM
  insightType   String
  mood          String
  title         String
  content       String
  severity      String @default("INFO")
  sparklineJson Json?
  metadata      Json?

  user User @relation(fields: [userId], references: [id])

  createdAt DateTime @default(now())
}

model AiInsightJob {
  id           String  @id @default(uuid())
  userId       String
  month        String // YYYY-MM
  status       String  @default("PENDING")
  inputJson    Json?
  outputJson   Json?
  errorMessage String?

  user User @relation(fields: [userId], references: [id])

  createdAt  DateTime  @default(now())
  finishedAt DateTime?
}
