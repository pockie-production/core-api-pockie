NODE_ENV=development
PORT=3000

DATABASE_URL="postgresql://pockie:pockie_dev_password@postgres:5432/pockie_db?schema=public"

JWT_ACCESS_SECRET="change_me_access_secret"
JWT_REFRESH_SECRET="change_me_refresh_secret"
JWT_ACCESS_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="30d"

MINIO_ENDPOINT="minio"
MINIO_PORT=9000
MINIO_ACCESS_KEY="pockie_minio"
MINIO_SECRET_KEY="pockie_minio_password"
MINIO_BUCKET="pockie-files"
MINIO_USE_SSL=false

# ==========================
# VNPT eKYC
# ==========================

VNPT_EKYC_MODE=mock

VNPT_EKYC_BASE_URL=https://api.idg.vnpt.vn

# Secret values - user will fill later
VNPT_EKYC_ACCESS_TOKEN=
VNPT_EKYC_TOKEN_ID=
VNPT_EKYC_TOKEN_KEY=

# Non-private default from API docs
VNPT_EKYC_MAC_ADDRESS_OR_TOKEN=TEST1
VNPT_EKYC_BODY_TOKEN=TEST1

# Hash returned by VNPT upload file is valid for 7 days
VNPT_EKYC_HASH_TTL_DAYS=7

# Endpoint paths
VNPT_EKYC_UPLOAD_ENDPOINT=/file-service/v1/addFile
VNPT_EKYC_OCR_APP_ENDPOINT=/ai/v1/ocr/id
VNPT_EKYC_OCR_WEB_ENDPOINT=/ai/v1/web/ocr/id
VNPT_EKYC_CARD_LIVENESS_APP_ENDPOINT=/ai/v1/card/liveness
VNPT_EKYC_CARD_LIVENESS_WEB_ENDPOINT=/ai/v1/web/card/liveness
VNPT_EKYC_FACE_LIVENESS_2D_ENDPOINT=/ai/v1/face/liveness
VNPT_EKYC_FACE_LIVENESS_3D_APP_ENDPOINT=/ai/v1/face/liveness-3d
VNPT_EKYC_FACE_LIVENESS_3D_WEB_ENDPOINT=/ai/v1/web/face/liveness-3d
VNPT_EKYC_FACE_COMPARE_APP_ENDPOINT=/ai/v1/face/compare
VNPT_EKYC_FACE_COMPARE_WEB_ENDPOINT=/ai/v1/web/face/compare
VNPT_EKYC_FACE_COMPARE_GENERAL_ENDPOINT=/v1/face/compare-general
VNPT_EKYC_MASK_FACE_APP_ENDPOINT=/ai/v1/face/mask
VNPT_EKYC_MASK_FACE_WEB_ENDPOINT=/ai/v1/web/face/mask

# Default behavior
VNPT_EKYC_DEFAULT_DOCUMENT_TYPE=-1
VNPT_EKYC_VALIDATE_POSTCODE=true
VNPT_EKYC_DEFAULT_CROP_PARAM=0.14,0.3
VNPT_EKYC_DEFAULT_COMPARE_GENERAL_THRESHOLD=normal

# Thresholds from docs/recommended usage
VNPT_EKYC_FACE_BLUR_THRESHOLD=0.52
VNPT_EKYC_FACE_LIVENESS_REAL_MAX_PROB=0.5
VNPT_EKYC_CARD_FACE_SWAPPING_THRESHOLD=0.6
VNPT_EKYC_CARD_FAKE_LIVENESS_THRESHOLD=0.55
VNPT_EKYC_CARD_FAKE_PRINT_PHOTO_THRESHOLD=0.5

# ==========================
# VNPT VnSocial
# ==========================

VNSOCIAL_MODE=mock
VNSOCIAL_BASE_URL=https://api-vnsocialplus.vnpt.vn/social-api/v1

# Primary credential for the hackathon account.
# Do not commit real tokens.
VNSOCIAL_ACCESS_TOKEN=

# Default live auth style uses Authorization: Bearer <token>.
# Set to x-access-token only if VNPT enables the older VnSocial contract.
VNSOCIAL_AUTH_HEADER=Authorization

# Optional fallback if VNPT later enables token refresh by username/password.
VNSOCIAL_USERNAME=
VNSOCIAL_PASSWORD=
VNSOCIAL_LOGIN_ENDPOINT=/login

VNSOCIAL_PROJECTS_ENDPOINT=/projects
VNSOCIAL_TOPIC_POSTS_ENDPOINT=/projects/posts
VNSOCIAL_SOURCE_POSTS_ENDPOINT=/source-follow/posts
VNSOCIAL_HOT_KEYWORDS_ENDPOINT=/projects/hot-keywords
VNSOCIAL_HOT_POSTS_ENDPOINT=/projects/hot-posts

# ==========================
# VNPT SmartBot
# ==========================

VNPT_SMARTBOT_MODE=mock
VNPT_SMARTBOT_BASE_URL=https://assistant-stream.vnpt.vn
VNPT_SMARTBOT_ENDPOINT=/v1/conversation
VNPT_SMARTBOT_BOT_ID=
VNPT_SMARTBOT_TOKEN_ID=
VNPT_SMARTBOT_TOKEN_KEY=
VNPT_SMARTBOT_ACCESS_TOKEN=
VNPT_SMARTBOT_INPUT_CHANNEL=app
VNPT_SMARTBOT_AUTH_BASE_URL=https://api.idg.vnpt.vn
VNPT_SMARTBOT_AUTH_ENDPOINT=/auth/oauth/token
VNPT_SMARTBOT_USERNAME=
VNPT_SMARTBOT_PASSWORD=
